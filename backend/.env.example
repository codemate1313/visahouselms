# Copy to .env and fill in real values. Never commit .env.

# MySQL 8 connection (point at any reachable instance - local install, remote dev DB, etc.)
DATABASE_URL=mysql+pymysql://ielts_user:changeme@localhost:3306/ielts_lms

# JWT
JWT_SECRET_KEY=change-this-to-a-long-random-string
APP_ENVIRONMENT=development
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Refresh tokens are stored only in an HttpOnly cookie.
REFRESH_COOKIE_NAME=ielts_lms_refresh
REFRESH_COOKIE_SAMESITE=lax
# Set only when the API and frontend share a parent domain.
REFRESH_COOKIE_DOMAIN=
# Public frontend base URL
FRONTEND_URL=http://localhost:5173

# CORS - comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local file storage root (relative paths resolve against backend/)
STORAGE_DIR=../storage

# Fernet key for encrypting sensitive settings (SMTP password, FCM JSON).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_ENCRYPTION_KEY=

# Public registration abuse protection, per API process and client IP.
REGISTRATION_RATE_LIMIT=5
REGISTRATION_RATE_WINDOW_SECONDS=3600

# Directory containing mysqldump / mysql client binaries (for backups)
MYSQL_BIN_DIR=/opt/homebrew/opt/mysql/bin

# First super admin, created by scripts/seed_super_admin.py
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin
